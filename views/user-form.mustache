{{> head}}
{{> header}}

<main>
  <h1>{{title}}</h1>

  {{#error}}
  <div class="alert error" role="alert" aria-live="assertive">
    {{{error}}}
  </div>
  {{/error}}

  <form method="POST" action="/organiser/users" class="user-form">
    <div class="form-group">
      <label for="name">Full Name *</label>
      <input 
        type="text" 
        id="name" 
        name="name" 
        required 
        value="{{user.name}}"
        placeholder="John Doe"
      />
    </div>

    <div class="form-group">
      <label for="email">Email Address *</label>
      <input 
        type="email" 
        id="email" 
        name="email" 
        required 
        value="{{user.email}}"
        placeholder="user@example.com"
      />
    </div>

    <div class="form-group">
      <label for="role">Role *</label>
      <select id="role" name="role" required>
        <option value="">-- Select --</option>
        <option value="student" {{#role.isStudent}}selected{{/role.isStudent}}>Student</option>
        <option value="organiser" {{#role.isOrganiser}}selected{{/role.isOrganiser}}>Organiser</option>
      </select>
    </div>

    <div class="form-group">
      <label for="password">Password *</label>
      <input 
        type="password" 
        id="password" 
        name="password" 
        required 
        placeholder="At least 6 characters"
      />
    </div>

    <div class="form-group">
      <label for="passwordConfirm">Confirm Password *</label>
      <input 
        type="password" 
        id="passwordConfirm" 
        name="passwordConfirm" 
        required 
        placeholder="Confirm password"
      />
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Create User</button>
      <a href="/organiser/users" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</main>

{{> footer}}
