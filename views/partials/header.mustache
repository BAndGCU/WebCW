<header class="site-header" role="banner">
  <div class="wrap">
    <a href="/" class="brand" aria-label="Yoga Studio - Home">
      🧘 Yoga Studio
    </a>
    <nav aria-label="Main navigation">
      <a href="/" aria-current="{{#isHome}}page{{/isHome}}">Home</a>
      <a href="/courses" aria-current="{{#isCourses}}page{{/isCourses}}">Courses</a>
    </nav>
    <div class="user">
      {{#user}}
        {{#isOrganiser}}
          <a href="/organiser" class="btn btn-secondary btn-small">Dashboard</a>
        {{/isOrganiser}}
        <span class="user-greeting" aria-label="Logged in as {{name}}">
          {{name}}
        </span>
        <a href="/auth/logout" class="btn btn-secondary">Logout</a>
      {{/user}}
      {{^user}}
        <a href="/auth/login" class="btn btn-primary">Login</a>
      {{/user}}
    </div>
  </div>
</header>
