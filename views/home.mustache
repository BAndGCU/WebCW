{{> head}}
{{> header}}
<main>

  <div>
    <p>Welcome to the Local Yoga Studio website!</p>
    <p>We operate a wide range of yoga courses for all skill levels.</p>
    <p>Browse our available courses to find one that's right for you!</p>
  </div>
  <h1>Upcoming Yoga Courses</h1>

  <div class="cards">
    {{#courses}}
    <article class="card course-card" aria-labelledby="course-{{id}}-title">
      <h2 id="course-{{id}}-title"><a href="/courses/{{id}}">{{title}}</a></h2>
      
      <div class="course-meta" aria-label="Course attributes">
        <span class="badge level" aria-label="Level: {{level}}">{{level}}</span>
        <span class="badge type" aria-label="Type: {{type}}">{{type}}</span>
        {{#allowDropIn}}
        <span class="badge dropin" aria-label="Drop-in sessions available">Drop-in OK</span>
        {{/allowDropIn}}
      </div>

      <p class="course-text">{{description}}</p>

      <div class="course-details">
        <div class="detail">
          <strong>Duration:</strong>
          <span>{{startDate}} – {{endDate}}</span>
          <span aria-label="Total sessions: {{sessionsCount}}">({{sessionsCount}} sessions)</span>
        </div>
        <div class="detail">
          <strong>Price:</strong>
          <span aria-label="Price: {{price}}">{{price}}</span>
        </div>
        <div class="detail">
          <strong>Location:</strong>
          <span>{{location}}</span>
        </div>
        <div class="detail">
          <strong>Next session:</strong>
          <span>{{nextSession}}</span>
        </div>
      </div>

      <a href="/courses/{{id}}" class="btn btn-primary">View &amp; Book</a>
    </article>
    {{/courses}}

    {{^courses}}
      <p>No courses available yet.</p>
    {{/courses}}
  </div>
</main>

{{> footer}}
