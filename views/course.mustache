
{{> head}}
{{> header}}

<main>
  <article class="course-detail">
    <h1>{{course.title}}</h1>
    
    {{#error}}
    <div class="alert error" role="alert" aria-live="assertive">
      {{{error}}}
    </div>
    {{/error}}
    
    <div class="course-meta">
      <span class="badge level">{{course.level}}</span>
      <span class="badge type">{{course.type}}</span>
      {{#course.allowDropIn}}
      <span class="badge dropin">Drop-in available</span>
      {{/course.allowDropIn}}
    </div>

    <div class="course-info">
      <div class="info-row">
        <strong>Duration:</strong>
        <span>{{course.startDate}} – {{course.endDate}}</span>
      </div>
      <div class="info-row">
        <strong>Price:</strong>
        <span>{{course.price}}</span>
      </div>
      <div class="info-row">
        <strong>Location:</strong>
        <span>{{course.location}}</span>
      </div>
    </div>

    <p class="description">{{course.description}}</p>

    {{#user}}
    <section class="booking-section">
      <h2>Book the full course</h2>
      <form action="/courses/{{course.id}}/book" method="post">
        <button class="btn btn-primary" type="submit">Book full course</button>
      </form>
    </section>
    {{/user}}

    {{^user}}
    <section class="booking-section">
      <p class="alert info">
        <a href="/auth/login">Login</a> to book courses. If you need an account, ask an organiser.
      </p>
    </section>
    {{/user}}

    <section class="sessions-section">
      <h2>Sessions</h2>
      <table class="sessions-table">
        <thead>
          <tr>
            <th>Start</th>
            <th>End</th>
            <th>Location</th>
            <th>Capacity</th>
            <th>Booked</th>
            <th>Remaining</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          {{#sessions}}
          <tr>
            <td>{{start}}</td>
            <td>{{end}}</td>
            <td>{{location}}</td>
            <td>{{capacity}}</td>
            <td>{{booked}}</td>
            <td class="remaining-{{#remaining}}available{{/remaining}}{{^remaining}}full{{/remaining}}">
              {{remaining}}
            </td>
            <td>
              {{#user}}
                {{#course.allowDropIn}}
                  <form action="/sessions/{{id}}/book" method="post" style="display:inline;">
                    <button class="btn btn-small" type="submit" {{^remaining}}disabled{{/remaining}}>
                      {{#remaining}}Book{{/remaining}}{{^remaining}}Full{{/remaining}}
                    </button>
                  </form>
                {{/course.allowDropIn}}
                {{^course.allowDropIn}}
                  <span class="muted">Drop-ins disabled</span>
                {{/course.allowDropIn}}
              {{/user}}
              {{^user}}
                <span class="muted">Login to book</span>
              {{/user}}
            </td>
          </tr>
          {{/sessions}}
        </tbody>
      </table>
    </section>
  </article>
</main>

{{> footer}}
